# karmyogi environment configuration (copy to `.env` and fill in real values).
#
# IMPORTANT: `.env` is gitignored. Leave any key blank or as a placeholder to
# DISABLE that feature — the app then runs fully open with NO auth gate and NO
# tracking (graceful degradation). The auth gate + Firestore tracking ONLY
# activate once real Firebase values are present below.
#
# These are CLIENT-SIDE keys (exposed in the built JS) — that is expected for
# Firebase web apps; security is enforced by Firebase Auth + Firestore rules
# (see firestore.rules), NOT by hiding these. NEVER put admin / service-account
# secrets here.

# --- Firebase (Google sign-in + Firestore activity tracking) ---
# From Firebase console → Project settings → Your apps → Web app → SDK config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — enables Firebase Analytics when set (Google Analytics property).
VITE_FIREBASE_MEASUREMENT_ID=

# --- Firebase App Check (abuse / cost protection) ---
# Public reCAPTCHA v3 site key. When set, the app attests requests to Firebase via
# App Check so bots/scripts can't pound Firestore/Storage/Auth and inflate the
# bill. Safe to ship (public key). Leave BLANK to disable (no-op). Setup: Firebase
# console → App Check → register the Web app with reCAPTCHA v3, then Monitor →
# Enforce on Firestore/Storage/Auth. (Local dev prints a debug token to register.)
VITE_RECAPTCHA_SITE_KEY=

# --- Super-admin (/admin console) ---
# Email allowed to open the /admin console and view ALL users' activity. Defaults
# to hemangjoshi37a@gmail.com if blank. NOTE: this is only the client UX gate —
# the REAL enforcement is the hardcoded admin email in `firestore.rules`. If you
# change this, also change the email in firestore.rules and re-publish the rules.
VITE_ADMIN_EMAIL=

# --- dev-logs bug-report overlay ---
# URL of a running dev-logs server (`npx @hemangjoshi37a/dev-logs`, default
# http://localhost:4445). Leave blank to use the localhost default in dev and to
# hide the overlay in production.
VITE_DEVLOGS_ENDPOINT=
