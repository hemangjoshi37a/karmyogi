# user-provided CAD test artifacts (not part of the app)
OM MANDALA.*
*.cdr

# Local STL test fixtures — large binaries, kept on disk but never tracked
# (some exceed GitHub's 100 MB file limit and broke `git push`).
test_stl_files/

# dev scratch (camera frames sent from the browser, UI screenshots)
.camera-frames/
.ui-shots/
.machine-bridge/

# Stray editor/agent config (do not track)
.antigravitycli/

# Interrupted-upload temp leftovers in controllers_3d/ (often root-owned and
# unreadable, which aborts `git add .`). The real models — controllers_3d/*.step
# and public/controllers_3d/ — are tracked normally.
controllers_3d/*.tmp-*
