# Cloudflare Pages headers — hardened for karmyogi (static SPA).
#
# NOTE on CSP: it ships as Content-Security-Policy-REPORT-ONLY first, so it can
# NEVER break the app — it only logs violations to the browser console. After a
# redeploy, exercise every feature (Google sign-in, 3D/WebGL, Carving WASM,
# camera, serial/BLE connect) and watch for CSP violation reports; once clean,
# rename the header to `Content-Security-Policy` (drop `-Report-Only`) to enforce.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site
  Permissions-Policy: serial=(self), usb=(self), bluetooth=(self), camera=(self), microphone=(), geolocation=(), payment=()
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'wasm-unsafe-eval' https://apis.google.com https://www.gstatic.com https://www.google.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.googleusercontent.com https://www.google-analytics.com; font-src 'self' data:; worker-src 'self' blob:; child-src 'self' blob:; connect-src 'self' blob: data: https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://*.firebasestorage.googleapis.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://www.googleapis.com https://www.google-analytics.com ws: wss:; frame-src 'self' https://*.firebaseapp.com https://accounts.google.com https://apis.google.com https://www.google.com; manifest-src 'self'
